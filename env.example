# Copie para .env nesta pasta e preencha.

# Jira Cloud (API token: https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_BASE_URL=https://sua-org.atlassian.net
JIRA_USER=seu.email@empresa.com.br
JIRA_TOKEN=seu_api_token_atlassian

# Opcional
# JIRA_AGILE_BASE_URL=https://sua-org.atlassian.net/rest/agile/1.0
# IDs dos boards Agile (separados por vírgula). Se definido, antes da extração o script percorre as
# issues de cada board, recolhe assignees com e-mail e cria/atualiza developers.json (categoria jira_boards).
# JIRA_BOARD_ID=455,451,453

# Mapeamento de Lane: JSON que associa issueType (em minúsculas) → lane ('inovacao' | 'magica' | 'outros').
# Se omitido, usa o mapa padrão embutido (hipótese/experimento/sub-tarefa → inovacao; sustentação/bug → magica).
# Exemplo customizado para o seu projeto:
# JIRA_LANE_MAP={"hipótese":"inovacao","experimento":"inovacao","sub-tarefa":"inovacao","sustentação":"magica","bug":"magica","história":"inovacao","epic":"inovacao"}

# MongoDB (gravação na coleção issues_dora_flow)
MONGO_URI=mongodb://localhost:27017
# Base de dados (igual ao script do monorepo)
MONGO_KR_DB=agent-rag
# ou: MONGO_DORA_DB=agent-rag

# Squad por projeto/board (na raiz do developers.json, preservado pela sync):
# - squadByProjectKey: { "BP": { "squad": "...", "tribe": "..." } } — prioridade 1 na exportação.
# - squadByBoardId: { "407": { "squad": "...", "tribe": "..." } } — prioridade 2: API Agile liga cada board
#   (ids em JIRA_BOARD_ID) aos project keys; primeiro board na lista vence se o projeto aparecer em mais do que um.
# Se não houver match, usa squad/tribe do assignee em developers.json (prioridade 3).

# Lista de pessoas (padrão: ./developers.json nesta pasta).
# Se estiver dentro do repo agent-rag: cp ../config/developers.json ./developers.json
# DEVELOPERS_JSON=/caminho/absoluto/developers.json
# DEVELOPERS_JSON=./meu-time.json
